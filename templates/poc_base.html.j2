<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
{% if viewport_width %}
<meta name="viewport" content="width={{ viewport_width }}, initial-scale=1">
{% else %}
<meta name="viewport" content="width=device-width, initial-scale=1">
{% endif %}
<title>{{ page_title }}</title>
<style>
    /*
        Clickjacking Tester -- Generated Proof of Concept
        For authorized security testing purposes only.
    */
    html, body {
        margin: 0;
        padding: 0;
        min-height: 100%;
        background: {{ background_color }};
        {% if background_image_url %}
        background-image: url('{{ background_image_url }}');
        background-size: cover;
        background-position: center;
        {% endif %}
        font-family: -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        overflow: hidden;
    }

    .cjt-banner {
        position: relative;
        z-index: 9999;
        background: #111318;
        color: #f5f5f7;
        padding: 10px 16px;
        font-size: 13px;
        line-height: 1.5;
        border-bottom: 3px solid #ff5252;
    }

    .cjt-banner b { color: #ff8a80; }

    .cjt-target-frame {
        position: absolute;
        top: {{ iframe_top }}px;
        left: {{ iframe_left }}px;
        width: {{ iframe_width }};
        height: {{ iframe_height }};
        opacity: {{ iframe_opacity }};
        z-index: {{ iframe_z_index }};
        border: 0;
    }

    {% if overlay_enabled %}
    .cjt-overlay {
        position: absolute;
        top: {{ overlay_top }}px;
        left: {{ overlay_left }}px;
        z-index: {{ overlay_z_index }};
        pointer-events: none;
    }

    {% if overlay_kind == "button" %}
    .cjt-fake-button {
        pointer-events: none;
        background: linear-gradient(180deg, #34c759, #2aa64c);
        color: #ffffff;
        font-weight: 600;
        font-size: 16px;
        padding: 14px 32px;
        border-radius: 8px;
        box-shadow: 0 4px 14px rgba(0,0,0,0.25);
        text-align: center;
        user-select: none;
    }
    {% elif overlay_kind == "login" %}
    .cjt-fake-login {
        pointer-events: none;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.25);
        padding: 24px;
        width: 300px;
    }
    .cjt-fake-login h3 { margin: 0 0 12px; font-size: 16px; color: #1c1c1e; }
    .cjt-fake-login input {
        width: 100%;
        box-sizing: border-box;
        padding: 10px;
        margin-bottom: 10px;
        border: 1px solid #d1d1d6;
        border-radius: 6px;
        font-size: 14px;
    }
    .cjt-fake-login button {
        width: 100%;
        padding: 10px;
        background: #007aff;
        color: #fff;
        border: 0;
        border-radius: 6px;
        font-weight: 600;
    }
    {% elif overlay_kind == "popup" %}
    .cjt-fake-popup {
        pointer-events: none;
        background: #ffffff;
        border-radius: 14px;
        box-shadow: 0 12px 40px rgba(0,0,0,0.3);
        padding: 28px;
        width: 340px;
        text-align: center;
    }
    .cjt-fake-popup h3 { margin: 0 0 10px; font-size: 18px; color: #1c1c1e; }
    .cjt-fake-popup p { margin: 0 0 18px; font-size: 14px; color: #636366; }
    .cjt-fake-popup button {
        padding: 10px 24px;
        background: #ff9500;
        color: #fff;
        border: 0;
        border-radius: 8px;
        font-weight: 600;
    }
    {% endif %}
    {% endif %}

    {% if custom_css %}
    /* --- Custom CSS provided by user --- */
    {{ custom_css }}
    {% endif %}
</style>
</head>
<body>
<div class="cjt-banner">
    <b>Clickjacking Tester PoC</b> &mdash; If target content is visible below, framing was NOT blocked.
    For authorized security testing only.
</div>

{% if target_url %}
<iframe class="cjt-target-frame" src="{{ target_url }}"
        sandbox="allow-scripts allow-same-origin allow-forms"
        loading="eager"></iframe>
{% endif %}

{% if overlay_enabled %}
<div class="cjt-overlay">
    {% if overlay_kind == "button" %}
    <div class="cjt-fake-button">{{ overlay_text }}</div>
    {% elif overlay_kind == "login" %}
    <div class="cjt-fake-login">
        <h3>Sign in to continue</h3>
        <input type="text" placeholder="Username" readonly>
        <input type="password" placeholder="Password" readonly>
        <button type="button">{{ overlay_text }}</button>
    </div>
    {% elif overlay_kind == "popup" %}
    <div class="cjt-fake-popup">
        <h3>Special Offer!</h3>
        <p>{{ overlay_text }}</p>
        <button type="button">Claim Now</button>
    </div>
    {% endif %}
    {% if overlay_image_url %}
    <img src="{{ overlay_image_url }}" alt="overlay" style="max-width:320px;display:block;margin-top:12px;">
    {% endif %}
</div>
{% endif %}

{% if custom_html %}
<!-- --- Custom HTML provided by user --- -->
{{ custom_html | safe }}
{% endif %}

{% if custom_js %}
<script>
// --- Custom JavaScript provided by user ---
{{ custom_js | safe }}
</script>
{% endif %}
</body>
</html>
